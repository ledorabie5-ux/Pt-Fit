rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net Catch-All (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL REUSABLE HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // In preview/dev environment, or for demo user accounts, allow seamless access
    function isDevBypass() {
      return request.auth == null || request.auth.uid == "demo_admin_uid" || request.auth.uid.startsWith("demo_");
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "belalrabe1907@gmail.com" ||
        request.auth.token.email == "admin@ptfit.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // --- COLLECTION RULES MATCHES ---

    // 1. Users Collection
    match /users/{userId} {
      allow read, get, list: if isDevBypass() || isSignedIn();
      allow create: if isDevBypass() || isSignedIn();
      allow update: if isDevBypass() || isSignedIn();
      allow delete: if isDevBypass() || isAdmin();
    }

    // 2. Programs Collection
    match /programs/{traineeId} {
      allow read, get, list: if isDevBypass() || isSignedIn();
      allow create, update, write: if isDevBypass() || isSignedIn();
      allow delete: if isDevBypass() || isAdmin();
    }

    // 3. Progress Collection
    match /progress/{progressId} {
      allow read, get, list: if isDevBypass() || isSignedIn();
      allow create, update, write: if isDevBypass() || isSignedIn();
      allow delete: if isDevBypass() || isAdmin();
    }

    // 4. Messages Collection
    match /messages/{messageId} {
      allow read, get, list: if isDevBypass() || isSignedIn();
      allow create, update, write: if isDevBypass() || isSignedIn();
      allow delete: if isDevBypass() || isAdmin();
    }

    // 5. Chats Collection
    match /chats/{chatId} {
      allow read, get, list: if isDevBypass() || isSignedIn();
      allow create, update, write: if isDevBypass() || isSignedIn();
      allow delete: if isDevBypass() || isAdmin();
    }

    // 6. Notifications Collection
    match /notifications/{notifId} {
      allow read, get, list: if isDevBypass() || isSignedIn();
      allow create, update, write: if isDevBypass() || isSignedIn();
      allow delete: if isDevBypass() || isAdmin();
    }

    // 7. Exercise Videos Collection
    match /exercise_videos/{videoId} {
      allow read, get, list: if true;
      allow create, update, write, delete: if isDevBypass() || isSignedIn();
    }

    // 8. Workout Templates Collection
    match /workoutTemplates/{templateId} {
      allow read, get, list: if isDevBypass() || isSignedIn();
      allow create, update, write, delete: if isDevBypass() || isSignedIn();
    }

    // 9. Nutrition Templates Collection
    match /nutritionTemplates/{templateId} {
      allow read, get, list: if isDevBypass() || isSignedIn();
      allow create, update, write, delete: if isDevBypass() || isSignedIn();
    }
  }
}
